  "type": "module",
  "description": "clayjs: malleable HTML files. Save lifecycle for self-saving HTML.",
  "license": "MIT",
  "homepage": "https://clayjs.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/panphora/clayjs.git"
  },
  "files": [
    "clay.js",
    "clay-ui.js",
    "clay-events.js",
    "clay-options.js",
    "clay-dom.js",
    "all.js",
